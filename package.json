{
  "name": "moar",
  "version": "0.3.0",
  "description": "Multi-platform Open-source Application Registry",
  "main": "main.js",
  "scripts": {
    "build": "rollup -c --bundleConfigAsCjs",
    "dev": "rollup -c -w",
    "start": "sirv public --no-clear --port 8888",
    "electron": "wait-on http://localhost:8888 && electron .",
    "electron-dev": "concurrently \"npm run dev\" \"npm run electron\"",
    "preelectron-pack": "npm run build",
    "electron-pack": "electron-builder"
  },
  "repository": "https://gitopia.com/moar/moar-desktop",
  "keywords": [
    "web3"
  ],
  "author": "Moar DAO",
  "license": "GPLV3",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^17.0.0",
    "@rollup/plugin-node-resolve": "^11.0.0",
    "concurrently": "^8.1.0",
    "electron": "^25.0.1",
    "electron-builder": "^23.6.0",
    "rollup": "^2.3.4",
    "rollup-plugin-css-only": "^3.1.0",
    "rollup-plugin-livereload": "^2.0.0",
    "rollup-plugin-svelte": "^7.0.0",
    "rollup-plugin-terser": "^7.0.0",
    "sirv-cli": "^2.0.0",
    "svelte": "^3.0.0",
    "svelte-time": "^0.7.2",
    "wait-on": "^7.0.1"
  },
  "dependencies": {
    "deep-equal": "^2.2.1",
    "electron-hostile": "^1.1.1",
    "electron-serve": "^1.1.0",
    "electron-store": "^8.1.0",
    "http-proxy": "^1.18.1",
    "ipfs-http-client": "^60.0.1",
    "is-port-reachable": "^4.0.0",
    "node-fetch": "^3.3.1"
  },
  "build": {
    "directories": {
      "output": "dist"
    },
    "appId": "com.octalmage.moar",
    "productName": "Moar",
    "mac": {
      "icon": "build/logo.icns"
    },
    "win": {
      "icon": "build/logo.png",
      "target": "zip"
    }
  }
}
